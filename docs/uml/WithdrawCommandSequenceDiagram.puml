@startuml
title WithdrawCommand Sequence Diagram

actor ":User" as User
participant ":MediStock" as App
participant ":Ui" as Ui
participant ":Parser" as Parser
participant ":Inventory" as Inventory
participant ":InventoryItem" as Item

User -> App : run "withdraw n/<name> q/<quantity>"
ref over App, Ui, Parser
    Input Parsing Sequence
end
opt input.startsWith("withdraw")
    create ":WithdrawCommand" as WithdrawCommand
    Parser -> WithdrawCommand : new WithdrawCommand(name, quantity)
end
App -> WithdrawCommand ++: execute(inventory, ui, histories)

WithdrawCommand -> Inventory ++: getItem(name)
return item

WithdrawCommand -> Item ++: withdraw(quantity)

Item -> Item : sortAndMarkExpiredBatches()
activate Item
deactivate Item

loop remaining > 0 and batches left
    alt batch is expired
        Item -> Item : skip batch
        activate Item
        deactivate Item
    else batch not expired
        alt batch quantity <= remaining
            Item -> Item : remove batch
            activate Item
            deactivate Item
        else batch quantity > remaining
            Item -> Item : reduceQuantity(remaining)
            activate Item
            deactivate Item
        end
    end
end

return withdrawnQuantity

WithdrawCommand -> Ui ++: printWithdraw(quantity, withdrawnQuantity, item)
alt withdrawnQuantity < quantity
    Ui -> Ui : print top-up warning
    activate Ui
    deactivate Ui
end
deactivate Ui

ref over App
    Local Storage Saving
end
@enduml
